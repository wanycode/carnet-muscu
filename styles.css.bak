@import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&display=swap');:root{--ink:#142016;--green:#1c291e;--lime:#d5ff3e;--line:#e0e5dd;--muted:#6c756c;--bg:#f7f8f5}*{box-sizing:border-box}body{margin:0;font-family:Manrope,Arial;background:var(--bg);color:var(--ink)}aside{position:fixed;inset:0 auto 0 0;width:235px;background:var(--green);color:#e9f0e8;padding:30px 18px;display:flex;flex-direction:column}.logo{font-weight:800;font-size:17px;display:flex;gap:10px;align-items:center;color:white;text-decoration:none;line-height:1.05}.logo:first-letter{background:var(--lime);color:var(--green);padding:7px 10px;border-radius:9px}nav{display:grid;gap:7px;margin-top:55px}nav a{color:#b5c0b4;text-decoration:none;padding:11px;border-radius:8px;font-size:13px;font-weight:700}nav a:hover{background:#334037;color:white}aside small{margin-top:auto;color:#aeb9ae;border-top:1px solid #3d4a40;padding:18px 7px;line-height:1.6}main{margin-left:235px;max-width:1420px;padding:50px clamp(25px,6vw,85px)}header{display:flex;justify-content:space-between;align-items:start;gap:18px;margin-bottom:29px}.eyebrow{font-size:10px;font-weight:800;letter-spacing:.13em;text-transform:uppercase;color:#748074;margin:0 0 8px}h1{font-size:38px;letter-spacing:-.06em;margin:0;line-height:1.1}h2{font-size:18px;margin:0;letter-spacing:-.035em}.sub{font-size:14px;color:var(--muted);margin:8px 0}.hidden{display:none}.btn{border:0;text-decoration:none;background:#eef1eb;color:var(--ink);padding:12px 15px;border-radius:8px;font:700 12px Manrope;cursor:pointer;display:inline-flex;align-items:center;justify-content:center}.lime{background:var(--lime)}.lime:hover{background:#c2eb30}.ghost{margin-top:15px}.full{width:100%;margin-top:18px}.next{padding:28px 30px;background:var(--green);color:white;border-radius:14px;display:flex;justify-content:space-between;align-items:center}.next .eyebrow,.next p:not(.eyebrow){color:#b4c0b4}.next h2{font-size:24px}.next p{font-size:13px}.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin:16px 0}.card{background:white;border:1px solid var(--line);border-radius:13px;padding:23px}.stat b{display:block;font-size:27px;letter-spacing:-.07em}.stat span{font-size:11px;color:var(--muted)}.grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}.empty{border:1px dashed #d7ddd4;color:var(--muted);padding:20px;border-radius:8px;font-size:12px;margin-top:20px}.bars{display:flex;gap:8px;justify-content:space-between;margin-top:28px}.bar{flex:1;text-align:center;font-size:10px;color:var(--muted)}.bar i{display:block;height:60px;background:#eef1ec;border-radius:5px;margin-bottom:7px}.bar i.active{background:var(--lime)}.templates{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px}.template h2{margin:4px 0 15px}.exercise{border-top:1px solid var(--line);padding:9px 0;font-size:12px;display:flex;justify-content:space-between;gap:8px}.exercise span{color:var(--muted);white-space:nowrap}.footer{display:flex;justify-content:flex-end;gap:8px;margin-top:15px}.delete{background:none;border:0;color:#ad4238;font:700 11px Manrope;cursor:pointer}.log{display:grid;grid-template-columns:1fr 260px;gap:16px;align-items:start}.form{padding:25px}.row{display:grid;grid-template-columns:1fr 170px;gap:13px}label{display:grid;gap:6px;font-size:11px;font-weight:800}input,select,textarea{border:1px solid #dce2d9;background:#fbfcfa;border-radius:7px;padding:9px;font:13px Manrope;color:var(--ink);width:100%}textarea{resize:vertical;min-height:85px}.logged{border-top:1px solid var(--line);padding:18px 0}.logged h3{font-size:14px;margin:0 0 9px}.logged table{width:100%;border-collapse:collapse;font-size:12px}.logged th{text-align:left;color:var(--muted);font-size:9px;text-transform:uppercase;padding:5px}.logged td{padding:4px}.remove{border:0;background:none;color:#9ca69b;font-size:16px;cursor:pointer}.addset{border:0;background:none;color:#426e22;font:700 11px Manrope;padding:9px 5px;cursor:pointer}.summary{position:sticky;top:18px;font-size:12px;color:var(--muted)}.summary b{font-size:18px;color:var(--ink);margin-right:5px}.summary hr{border:0;border-top:1px solid var(--line);margin:14px 0}.summary label{margin-top:20px}.history{display:grid;gap:10px}.historyItem{cursor:pointer;display:grid;grid-template-columns:140px 1fr auto;align-items:center;gap:15px}.historyItem time,.historyItem span{font-size:12px;color:var(--muted)}.historyItem b{font-size:15px}.chart label{max-width:260px}.chartBox{height:260px;margin-top:30px;display:flex;gap:10px;align-items:end;border-bottom:1px solid var(--line);padding:0 10px}.point{flex:1;height:100%;display:flex;justify-content:end;flex-direction:column;align-items:center;min-width:35px}.point i{width:30px;max-width:100%;background:var(--lime);border-radius:5px 5px 0 0;position:relative}.point b{position:absolute;top:-19px;font-size:9px;white-space:nowrap}.point span{font-size:9px;color:var(--muted);padding-top:7px}dialog{border:0;border-radius:14px;width:min(680px,calc(100vw - 25px));box-shadow:0 20px 70px #0005}dialog::backdrop{background:#13201499}dialog form{padding:25px}.close{float:right;border:0;background:none;font-size:25px;cursor:pointer}.prog{display:grid;grid-template-columns:1fr 65px 85px 90px 28px;gap:8px;border-top:1px solid var(--line);padding:13px 0}.prog label{font-size:9px}.actions{border-top:1px solid var(--line);margin-top:21px;padding-top:19px;display:flex;justify-content:flex-end;gap:8px}.mobile-nav{display:none}@media(max-width:760px){aside{display:none}main{margin:0;padding:16px 14px 92px;max-width:none}h1{font-size:32px}h2{font-size:18px}header{display:flex;flex-direction:column;align-items:flex-start;gap:18px}header > div{width:100%}header .btn{width:100%;max-width:none;margin-top:0}header .btn:first-of-type{margin-top:0}header .btn:not(:first-of-type){margin-top:14px}.next{display:block;padding:22px 18px;border-radius:18px} .next h2{font-size:22px} .next p{font-size:13px} .next .btn{width:100%;margin-top:18px} .stats{grid-template-columns:1fr;gap:14px;margin:18px 0}.grid,.templates,.log{grid-template-columns:1fr;gap:14px}.card{padding:18px}.summary{position:static;top:auto}.row{grid-template-columns:1fr;gap:10px}.prog{grid-template-columns:1fr;gap:10px}.prog label{font-size:10px}.historyItem{grid-template-columns:1fr;gap:14px;padding:14px}.historyItem time,.historyItem span{font-size:12px}.historyItem b{font-size:16px}.chart label{max-width:100%}.chartBox{height:200px;margin-top:22px}.bar i{height:46px}.logged th{font-size:9px}.logged td{padding:6px}.btn{width:100%;padding:14px 16px}.footer{flex-direction:column;align-items:stretch}.footer .btn{width:100%}.form{padding:18px}.templates{width:100%}.card.history{padding:18px}.mobile-nav{display:flex;position:fixed;left:0;right:0;bottom:0;z-index:20;justify-content:space-between;align-items:center;gap:6px;padding:8px 10px;background:var(--green);border-top:1px solid #334037;box-shadow:0 -10px 30px rgba(0,0,0,.18)}.mobile-nav a{flex:1;color:#d5e3d4;text-decoration:none;font-size:11px;text-align:center;padding:8px 5px;border-radius:12px;line-height:1.2}.mobile-nav a:hover,.mobile-nav a:focus{background:#334037;color:white}.mobile-nav a br{display:none}}</style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></style></sty